# Kubernetes
*.log
*.swp
*~

# Helm
charts/
*.tgz

# Temporary files
/tmp/
*.tmp

# IDE
.vscode/
.idea/
*.iml

# OS
.DS_Store
Thumbs.db

# Secrets (안전을 위해)
*secret*.yaml
# ...except the chart Secret TEMPLATE — it holds no real secrets (only .Values
# references, lookup-preserve logic, and placeholder defaults). It MUST be tracked
# or a clean deploy can't render JWT/LiteLLM/OM secrets (the reproducibility gap).
!helm/datapond/templates/secrets.yaml
*password*.txt
.env
.env.*

# User-specific values
my-values.yaml

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
backend/venv/

# Testing
# (backend/tests/ 자체는 버전관리 대상 — CI 단위테스트. 캐시만 무시)
backend/tests/**/__pycache__/
.pytest_cache/
pytest_cache/
.coverage
htmlcov/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
crash.log
